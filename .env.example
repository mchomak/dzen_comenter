# БД
DATABASE_URL=postgresql://dzen:dzen@localhost:5432/dzen_commenter

# AI
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=sk-your-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=512
AI_PROMPT_LANGUAGE=ru

# GigaChat (used when AI_PROVIDER=gigachat)
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_B2B
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api
GIGACHAT_MODEL=GigaChat-Pro
GIGACHAT_VERIFY_SSL_CERTS=true
# Optional path to a custom CA bundle. The Docker image installs the official
# Russian trusted root CA into its system trust store, so leave this empty.
GIGACHAT_CA_BUNDLE=

# Браузер / Дзен
USER_DATA_DIR=./user_data
STORAGE_STATE_PATH=./storage_state.json
HEADLESS=false
COMMENTS_URL=https://dzen.ru/
DZEN_LOGIN_PHONE=
DZEN_LOGIN_PASSWORD=
DZEN_LOGIN_TIMEOUT_MS=30000

# Цикл
POLL_INTERVAL=60
KEEPALIVE_INTERVAL=300
AUTO_PUBLISH=false
MAX_REPLIES_PER_CYCLE=10

# Telegram (авторизация/уведомления)
TELEGRAM_BOT_TOKEN=changeme
TELEGRAM_CHAT_ID=changeme
TELEGRAM_PROXY_URL=

# Email-фоллбэк
EMAIL_FALLBACK_LIST=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=changeme
SMTP_PASSWORD=changeme
SMTP_FROM=dzen-commenter@example.com

# Отсечки
MAX_COMMENT_AGE_DAYS=30
MAX_REPLY_LENGTH=200

# Промпт
PROMPT_CONFIG_PATH=./prompt_config.example.json

# VNC
VNC_PORT=5900
VNC_PASSWORD=changeme
NOVNC_PORT=6080
